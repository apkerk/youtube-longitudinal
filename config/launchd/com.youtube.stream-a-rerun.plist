<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.youtube.stream-a-rerun</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>-m</string>
        <string>src.collection.discover_intent</string>
        <string>--strategies</string>
        <string>base,safesearch,topicid,regioncode,duration</string>
        <string>--skip-first-video</string>
        <string>--output</string>
        <string>data/channels/stream_a/initial_20260222.csv</string>
        <string>--max-runtime</string>
        <string>14400</string>
        <string>--max-consecutive-errors</string>
        <string>5</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/katieapker/.youtube-longitudinal/repo</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>15</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/katieapker/.youtube-longitudinal/repo/data/logs/stream_a_rerun_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/katieapker/.youtube-longitudinal/repo/data/logs/stream_a_rerun_stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
